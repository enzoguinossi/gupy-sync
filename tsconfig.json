{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESnext",
		"moduleResolution": "Bundler",
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": false,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"],
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
